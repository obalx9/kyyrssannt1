# ====================================================================
# TIMEWEB CLOUD APPS - Переменные окружения для Backend API
# ====================================================================
# Скопируйте эти переменные в панель Timeweb → Переменные окружения

# ====================================================================
# 1. DATABASE_URL (ОБЯЗАТЕЛЬНО)
# ====================================================================
# Получите из: Timeweb → Облачные БД → PostgreSQL → Connection String
# Заменить: [username] [password] [host] [port] [database]

DATABASE_URL=postgresql://[username]:[password]@[host]:[port]/[database]

# Пример заполненного:
# DATABASE_URL=postgresql://postgres:your_secure_password@pg.timeweb.ru:5432/kursat_db

# ====================================================================
# 2. JWT_SECRET (ОБЯЗАТЕЛЬНО)
# ====================================================================
# Генерировать: openssl rand -hex 32
# Это будет использоваться для подписи JWT токенов
# ВАЖНО: Используйте криптостойкое значение!

JWT_SECRET=a3f8c9e2d1b4f7a5c8e9d2b3f4a5c6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# Как генерировать свое значение:
# Linux/Mac:   openssl rand -hex 32
# Windows:     [System.Convert]::ToBase64String((1..32 | % {[byte](Get-Random -Maximum 256)}))
# Онлайн:      https://www.random.org/strings/

# ====================================================================
# 3. NODE_ENV (ОБЯЗАТЕЛЬНО)
# ====================================================================
# Окружение приложения
# Значение: "production" для продакшена

NODE_ENV=production

# ====================================================================
# 4. PORT (ОБЯЗАТЕЛЬНО)
# ====================================================================
# Порт, на котором слушает приложение
# Значение: 3000

PORT=3000

# ====================================================================
# 5. ALLOWED_ORIGINS (ОБЯЗАТЕЛЬНО)
# ====================================================================
# CORS: домены, с которых можно делать запросы к API
# Разделить запятой без пробелов

ALLOWED_ORIGINS=https://your-frontend-domain.com,https://api.your-domain.com

# Примеры:
# - Один домен:
#   ALLOWED_ORIGINS=https://kursat.com
#
# - Несколько доменов:
#   ALLOWED_ORIGINS=https://kursat.com,https://app.kursat.com
#
# - С локальной разработкой:
#   ALLOWED_ORIGINS=https://kursat.com,http://localhost:5173
#
# - Для тестирования (не безопасно):
#   ALLOWED_ORIGINS=*

# ====================================================================
# ДОПОЛНИТЕЛЬНО (опционально, но рекомендуется)
# ====================================================================

# Настройки SSL (для продакшена с БД на Timeweb)
# Обычно уже настроено, но можно оставить:
# NODE_TLS_REJECT_UNAUTHORIZED=0

# Логирование (для отладки, опционально)
# DEBUG=express:*

# ====================================================================
# ✅ ИНСТРУКЦИЯ ПО ИСПОЛЬЗОВАНИЮ
# ====================================================================

# 1. Замените значения в этом файле на реальные:
#    - DATABASE_URL: получить из Timeweb БД
#    - JWT_SECRET: сгенерировать или скопировать
#    - ALLOWED_ORIGINS: указать домены вашего фронтенда
#
# 2. В панели Timeweb Cloud Apps заполните эти переменные:
#    - Облачные приложения → Ваше приложение → Переменные окружения
#    - Нажать [+] для каждой переменной
#    - Заполнить Имя и Значение
#    - Сохранить
#
# 3. Нажать "Перезагрузить приложение" или пересоберите его
#
# 4. Проверить работу:
#    curl https://your-api.timeweb.app/health

# ====================================================================
# ⚠️ ВАЖНО
# ====================================================================

# ❗ НЕ коммитьте этот файл с реальными значениями!
# ❗ Используйте только .env.example как шаблон
# ❗ Реальные переменные храните только в панели Timeweb

# ====================================================================
# 📞 ПРОВЕРКА ПОСЛЕ ДЕПЛОЯ
# ====================================================================

# Здоровье:
# GET https://your-api.timeweb.app/health
# Ответ: {"status":"ok","timestamp":"..."}

# Конфигурация:
# GET https://your-api.timeweb.app/api/env-check
# Показывает какие переменные установлены

# Диагностика БД (откройте в браузере):
# GET https://your-api.timeweb.app/api/diagnostics

# Таблицы БД:
# GET https://your-api.timeweb.app/api/db-tables

# ====================================================================
